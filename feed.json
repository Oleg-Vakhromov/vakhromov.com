            "content_html": "<section class=\"education-section\">\n<div class=\"media-container\" style=\"display: flex; align-items: center; margin-bottom: 0px;\">\n<div style=\"flex: 0 0 19%; margin-right: 20px;\"><figure class=\"post__image\"><img loading=\"lazy\"  src=\"https://vakhromov-com.vercel.app/media/posts/2/Ryerson-logo.png\" alt=\"Ryerson University\" width=\"180\" height=\"180\" sizes=\"(max-width: 48em) 100vw, 768px\" srcset=\"https://vakhromov-com.vercel.app/media/posts/2/responsive/Ryerson-logo-xs.png 300w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/Ryerson-logo-sm.png 480w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/Ryerson-logo-md.png 768w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/Ryerson-logo-lg.png 1024w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/Ryerson-logo-xl.png 1360w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/Ryerson-logo-2xl.png 1600w\"></figure></div>\n<div>\n<h3 style=\"margin: 0;\">Masters, International Economics and Finance</h3>\n<p>Ryerson University, Canada<br>2006 - 2008</p>\n</div>\n</div>\n<div class=\"media-container\" style=\"display: flex; align-items: center; margin-bottom: 10px;\">\n<div style=\"flex: 0 0 19%; margin-right: 20px;\"><figure class=\"post__image\"><img loading=\"lazy\"  src=\"https://vakhromov-com.vercel.app/media/posts/2/FHD.png\" alt=\"Fachhochschule Deggendorf\" width=\"200\" height=\"200\" sizes=\"(max-width: 48em) 100vw, 768px\" srcset=\"https://vakhromov-com.vercel.app/media/posts/2/responsive/FHD-xs.png 300w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/FHD-sm.png 480w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/FHD-md.png 768w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/FHD-lg.png 1024w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/FHD-xl.png 1360w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/FHD-2xl.png 1600w\"></figure></div>\n<div>\n<h3 style=\"margin: 0;\">International Business Administration</h3>\n<p>Deggendorf Institute of Technology<br>2001 - 2022</p>\n</div>\n</div>\n<div class=\"media-container\" style=\"display: flex; align-items: center; margin-bottom: 0px;\">\n<div style=\"flex: 0 0 19%; margin-right: 20px;\"><figure class=\"post__image\"><img loading=\"lazy\"  src=\"https://vakhromov-com.vercel.app/media/posts/2/UGGA.jpg\" alt=\"Ural State Mining University Logo\" width=\"200\" height=\"200\" sizes=\"(max-width: 48em) 100vw, 768px\" srcset=\"https://vakhromov-com.vercel.app/media/posts/2/responsive/UGGA-xs.jpg 300w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/UGGA-sm.jpg 480w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/UGGA-md.jpg 768w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/UGGA-lg.jpg 1024w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/UGGA-xl.jpg 1360w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/UGGA-2xl.jpg 1600w\"></figure></div>\n<div>\n<h3 style=\"margin: 0;\">Bachelor, Business Administration and Management</h3>\n<p>Ural State Mining University<br>2000 - 2005</p>\n</div>\n</div>\n<hr>\n<h2>Certifications</h2>\n<p> </p>\n<div class=\"media-container\" style=\"display: flex; align-items: center; margin-bottom: 0px;\">\n<div style=\"flex: 0 0 19%; margin-right: 20px;\"><figure class=\"post__image\"><img loading=\"lazy\"  src=\"https://vakhromov-com.vercel.app/media/posts/2/CFA-1.jpg\" alt=\"CFA Logo\" width=\"225\" height=\"225\" sizes=\"(max-width: 48em) 100vw, 768px\" srcset=\"https://vakhromov-com.vercel.app/media/posts/2/responsive/CFA-1-xs.jpg 300w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/CFA-1-sm.jpg 480w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/CFA-1-md.jpg 768w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/CFA-1-lg.jpg 1024w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/CFA-1-xl.jpg 1360w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/CFA-1-2xl.jpg 1600w\"></figure></div>\n<div>\n<h3 style=\"margin: 10px;\">Chartered Financial Analyst</h3>\n<p>Since 2012</p>\n</div>\n</div>\n<div class=\"media-container\" style=\"display: flex; align-items: center; margin-bottom: 0px;\">\n<div style=\"flex: 0 0 19%; margin-right: 20px;\"><figure class=\"post__image\"><img loading=\"lazy\"  src=\"https://vakhromov-com.vercel.app/media/posts/2/cams.jpg\" alt=\"CAMS Logo\" width=\"900\" height=\"900\" sizes=\"(max-width: 48em) 100vw, 768px\" srcset=\"https://vakhromov-com.vercel.app/media/posts/2/responsive/cams-xs.jpg 300w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/cams-sm.jpg 480w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/cams-md.jpg 768w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/cams-lg.jpg 1024w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/cams-xl.jpg 1360w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/cams-2xl.jpg 1600w\"></figure></div>\n<div>\n<h3 style=\"margin: 10px;\">Certified Anti-Money Laundering Specialist (CAMLS)</h3>\n<p>2021</p>\n</div>\n</div>\n<div class=\"media-container\" style=\"display: flex; align-items: center; margin-bottom: 0px;\">\n<div style=\"flex: 0 0 19%; margin-right: 20px;\"><figure class=\"post__image\"><img loading=\"lazy\"  src=\"https://vakhromov-com.vercel.app/media/posts/2/IBM.png\" alt=\"IBM Logo\" width=\"225\" height=\"225\" sizes=\"(max-width: 48em) 100vw, 768px\" srcset=\"https://vakhromov-com.vercel.app/media/posts/2/responsive/IBM-xs.png 300w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/IBM-sm.png 480w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/IBM-md.png 768w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/IBM-lg.png 1024w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/IBM-xl.png 1360w ,https://vakhromov-com.vercel.app/media/posts/2/responsive/IBM-2xl.png 1600w\"></figure></div>\n<div>\n<h3 style=\"margin: 10px;\">IBM Data Science Professional Certification</h3>\n<p>2020</p>\n</div>\n</div>\n</section>",
